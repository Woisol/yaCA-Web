{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "paths": {
      "@woisol-g/yaca/web-runtime.js": ["../../dist/web-runtime.d.ts"]
    }
  },
  "include": [
    "src/server.ts",
    "src/server/**/*.ts"
  ]
}
