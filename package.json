{
  "name": "@woisol-g/yaca-web",
  "version": "1.5.4",
  "description": "Web UI package for yaCA.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": "./dist/server.js",
    "./server.js": "./dist/server.js",
    "./server/prompt.js": "./dist/server/prompt.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "pnpm --filter @woisol-g/llm-html run build && vp dev",
    "build": "pnpm --filter @woisol-g/llm-html run build && tsc -b && vp build && tsc -p tsconfig.server.json",
    "lint": "pnpm --filter @woisol-g/llm-html run build && vp lint .",
    "preview": "vp preview"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.0",
    "@woisol-g/llm-html": "workspace:^",
    "lucide-react": "^1.14.0",
    "react": "=19.2.5",
    "react-dom": "=19.2.5",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "@woisol-g/yaca": "=1.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.11",
    "vite-plus": "^0.1.20"
  },
  "packageManager": "pnpm@11.0.9"
}
