{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@yaca/agent-core": ["../../packages/agent-core/src/index.ts"],
      "@yaca/agent-core/*.js": ["../../packages/agent-core/src/*.ts"],
      "@yaca/agent-core/*": ["../../packages/agent-core/src/*"],
      "@yaca/types": ["../../packages/shared/types/index.ts"],
      "@yaca/types/*.js": ["../../packages/shared/types/*.ts"],
      "@yaca/types/*": ["../../packages/shared/types/*"],
      "@yaca/ui": ["../../packages/shared/ui/src/index.ts"],
      "@yaca/ui/*.js": ["../../packages/shared/ui/src/*.ts"],
      "@yaca/ui/*": ["../../packages/shared/ui/src/*"],
      "@yaca/utils/*.js": ["../../packages/utils/*.ts"],
      "@yaca/utils/*": ["../../packages/utils/*"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["vite.config.ts"]
}
